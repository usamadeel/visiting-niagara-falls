{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/tours/",                              "destination": "/tours",                                          "permanent": true },
    { "source": "/attractions/",                        "destination": "/attractions",                                    "permanent": true },
    { "source": "/blog/",                               "destination": "/blog",                                           "permanent": true },
    { "source": "/maid-of-the-mist",                    "destination": "/attractions/maid-of-the-mist",                   "permanent": true },
    { "source": "/maid-of-the-mist/",                   "destination": "/attractions/maid-of-the-mist",                   "permanent": true },
    { "source": "/ten-thousand-buddhas-sarira-stupa",   "destination": "/attractions/ten-thousand-buddhas-sarira-stupa",  "permanent": true },
    { "source": "/ten-thousand-buddhas-sarira-stupa/",  "destination": "/attractions/ten-thousand-buddhas-sarira-stupa",  "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
