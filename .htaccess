# ==============================================================================
# .htaccess — Visiting Niagara Falls
# Optimized for Hostinger Shared Hosting (Apache / LiteSpeed)
# Author: Visiting Niagara Falls
# Version: 1.0
# ==============================================================================


# ==============================================================================
# 1. ENGINE & SERVER SIGNATURE
# ==============================================================================

Options -Indexes
Options -MultiViews
ServerSignature Off


# ==============================================================================
# 2. REWRITE ENGINE — BASE
# ==============================================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # ──────────────────────────────────────────────────────────────────────────
    # 2a. FORCE HTTPS (SSL)
    # Hostinger auto-provisions free SSL via Let's Encrypt
    # ──────────────────────────────────────────────────────────────────────────
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]


    # ──────────────────────────────────────────────────────────────────────────
    # 2b. FORCE WWW → NON-WWW (canonical domain: visitingniagarafalls.com)
    # Redirects www.visitingniagarafalls.com → visitingniagarafalls.com
    # ──────────────────────────────────────────────────────────────────────────
    RewriteCond %{HTTP_HOST} ^www\.visitingniagarafalls\.com$ [NC]
    RewriteRule ^ https://visitingniagarafalls.com%{REQUEST_URI} [R=301,L]


    # ──────────────────────────────────────────────────────────────────────────
    # 2c. REMOVE TRAILING SLASH (except directories)
    # ──────────────────────────────────────────────────────────────────────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]


    # ──────────────────────────────────────────────────────────────────────────
    # 2d. REMOVE .HTML EXTENSION from URLs (clean URLs)
    # e.g. /about.html → /about
    # ──────────────────────────────────────────────────────────────────────────
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^([^.]+)$ $1.html [L]

    # Redirect direct .html requests to clean URL (avoid duplicate content)
    RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]


    # ──────────────────────────────────────────────────────────────────────────
    # 2e. SEO-FRIENDLY URL ROUTING (future pages / CMS scalability)
    # ──────────────────────────────────────────────────────────────────────────

    # Destination pages
    RewriteRule ^niagara-falls-usa/?$            destinations/usa.html    [L]
    RewriteRule ^niagara-falls-canada/?$         destinations/canada.html [L]

    # Static pages
    RewriteRule ^about/?$        about.html   [L]
    RewriteRule ^contact/?$      contact.html [L]
    RewriteRule ^faq/?$          faq.html     [L]
    RewriteRule ^reviews/?$      reviews.html [L]


    # ──────────────────────────────────────────────────────────────────────────
    # 2f. BLOCK ACCESS TO SENSITIVE FILES
    # ──────────────────────────────────────────────────────────────────────────
    RewriteRule ^\.htaccess$        - [F,L]
    RewriteRule ^\.htpasswd$        - [F,L]
    RewriteRule ^\.env$             - [F,L]
    RewriteRule ^composer\.json$    - [F,L]
    RewriteRule ^composer\.lock$    - [F,L]
    RewriteRule ^package\.json$     - [F,L]
    RewriteRule ^package-lock\.json$ - [F,L]
    RewriteRule ^README\.md$        - [F,L]

</IfModule>


# ==============================================================================
# 3. CUSTOM ERROR PAGES
# ==============================================================================

ErrorDocument 400 /errors/400.html
ErrorDocument 401 /errors/401.html
ErrorDocument 403 /errors/403.html
ErrorDocument 404 /errors/404.html
ErrorDocument 500 /errors/500.html
ErrorDocument 503 /errors/503.html


# ==============================================================================
# 4. MIME TYPES
# ==============================================================================

<IfModule mod_mime.c>
    # Web fonts
    AddType font/woff                               .woff
    AddType font/woff2                              .woff2
    AddType application/vnd.ms-fontobject           .eot
    AddType font/ttf                                .ttf
    AddType font/otf                                .otf
    AddType image/svg+xml                           .svg

    # JavaScript
    AddType text/javascript                         .js .mjs

    # Web App Manifest
    AddType application/manifest+json               .webmanifest .json

    # Media
    AddType video/mp4                               .mp4
    AddType video/webm                              .webm
    AddType audio/mpeg                              .mp3
    AddType audio/ogg                               .ogg

    # Images
    AddType image/webp                              .webp
    AddType image/avif                              .avif

    # Data
    AddType text/xml                                .xml
    AddType text/calendar                           .ics

    # Charset for text files
    AddDefaultCharset utf-8
    AddCharset utf-8 .html .css .js .json .xml .webmanifest
</IfModule>


# ==============================================================================
# 5. COMPRESSION (mod_deflate / mod_brotli)
# Hostinger supports both on LiteSpeed servers
# ==============================================================================

<IfModule mod_deflate.c>
    # Enable compression
    SetOutputFilter DEFLATE

    # Compress all output labeled with one of the following MIME-types
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/atom+xml
    AddOutputFilterByType DEFLATE application/manifest+json
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE image/x-icon

    # Remove browser bugs (only needed for really old browsers)
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html

    # Don't compress already-compressed formats
    SetEnvIfNoCase Request_URI \
        \.(?:gif|jpe?g|png|webp|avif|mp4|webm|mp3|ogg|zip|gz|bz2|rar|7z|pdf)$ \
        no-gzip dont-vary

    # Make sure proxies don't deliver the wrong content
    Header append Vary User-Agent env=!dont-vary
</IfModule>

# Brotli compression (LiteSpeed on Hostinger)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml
    AddOutputFilterByType BROTLI_COMPRESS text/css text/javascript
    AddOutputFilterByType BROTLI_COMPRESS application/javascript
    AddOutputFilterByType BROTLI_COMPRESS application/json
    AddOutputFilterByType BROTLI_COMPRESS font/woff font/woff2
    AddOutputFilterByType BROTLI_COMPRESS image/svg+xml
</IfModule>


# ==============================================================================
# 6. BROWSER CACHING (Expires & Cache-Control)
# ==============================================================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                              "access plus 1 month"

    # HTML — short cache for dynamic content
    ExpiresByType text/html                     "access plus 1 hour"

    # CSS & JavaScript — long cache (use versioning/cache-busting in filenames)
    ExpiresByType text/css                      "access plus 1 year"
    ExpiresByType text/javascript               "access plus 1 year"
    ExpiresByType application/javascript        "access plus 1 year"

    # Images
    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/gif                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/avif                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon      "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType font/ttf                      "access plus 1 year"
    ExpiresByType font/otf                      "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"

    # Data & feeds
    ExpiresByType application/json              "access plus 0 seconds"
    ExpiresByType application/xml               "access plus 1 hour"
    ExpiresByType text/xml                      "access plus 1 hour"

    # Manifest & service worker
    ExpiresByType application/manifest+json     "access plus 1 week"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
    # Immutable assets (CSS, JS, fonts, images — use versioned filenames)
    <FilesMatch "\.(css|js|woff|woff2|ttf|otf|eot|ico|webp|avif|png|jpg|jpeg|gif|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML — revalidate on each request
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>

    # JSON / XML — no cache
    <FilesMatch "\.(json|xml)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>


# ==============================================================================
# 7. SECURITY HEADERS
# ==============================================================================

<IfModule mod_headers.c>

    # Strict Transport Security (HSTS) — force HTTPS for 1 year
    # Only enable after confirming SSL is fully working on Hostinger
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Clickjacking protection
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy (disable unused browser features)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

    # Content Security Policy
    # Allows: self, Google Fonts, Unsplash images, Google Analytics/Tag Manager
    # Adjust inline-script hash or use nonces in production
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https://images.unsplash.com https://www.google-analytics.com https://ssl.gstatic.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com; frame-src 'self' https://www.google.com https://www.youtube.com https://www.tripadvisor.com; object-src 'none'; base-uri 'self'; form-action 'self';"

    # Remove X-Powered-By header (security through obscurity)
    Header unset X-Powered-By
    Header always unset X-Powered-By

</IfModule>


# ==============================================================================
# 8. HOTLINK PROTECTION (prevent bandwidth theft for images)
# ==============================================================================

<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_REFERER} !^$
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?visitingniagarafalls\.com(/.*)?$ [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?google\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?bing\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?yahoo\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?facebook\.com [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?pinterest\.com [NC]
    RewriteRule \.(jpg|jpeg|png|gif|webp|avif|svg)$ - [F,NC,L]
</IfModule>


# ==============================================================================
# 9. BLOCK BAD BOTS & KNOWN MALICIOUS USER AGENTS
# ==============================================================================

<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (ahrefsbot|dotbot|semrushbot|majestic|blexbot|rogerbot) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (scrapy|wget|libwww-perl|python-urllib|nikto|sqlmap) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (masscan|zgrab|nmap|massex|httperf|apachebench|siege) [NC]
    RewriteRule ^ - [F,L]
</IfModule>

# Block empty User-Agent (bots without UA strings)
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} ^-?$
    RewriteRule ^ - [F,L]
</IfModule>


# ==============================================================================
# 10. BLOCK ACCESS TO SENSITIVE FILES & DIRECTORIES
# ==============================================================================

# Block access to hidden files/directories (dot files)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to specific file types that should never be public
<FilesMatch "\.(bak|backup|sql|sqlite|db|log|conf|config|ini|sh|bash|exe|dll|zip|tar|gz|7z|rar)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to version control directories
<IfModule mod_rewrite.c>
    RewriteRule ^(\.git|\.svn|\.hg|node_modules|vendor|\.DS_Store) - [F,L]
</IfModule>


# ==============================================================================
# 11. PERFORMANCE: KEEP-ALIVE & CONNECTION SETTINGS
# (Hostinger LiteSpeed supports these)
# ==============================================================================

<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>


# ==============================================================================
# 12. ETAGS (Improve Caching Validation)
# ==============================================================================

<IfModule mod_headers.c>
    Header unset ETag
</IfModule>
FileETag None


# ==============================================================================
# 13. CORS HEADERS (for fonts and web resources)
# ==============================================================================

<IfModule mod_headers.c>
    <FilesMatch "\.(woff|woff2|ttf|otf|eot|svg|css|js)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>


# ==============================================================================
# 14. GZIP FALLBACK VIA PHP (if mod_deflate unavailable on some Hostinger plans)
# ==============================================================================

# php_value output_buffering On
# php_value zlib.output_compression On
# Uncomment the above two lines ONLY if mod_deflate is not available


# ==============================================================================
# 15. LIMIT FILE UPLOAD SIZE (PHP settings on Hostinger)
# Adjust these via Hostinger hPanel > PHP Configuration if needed
# ==============================================================================

# php_value upload_max_filesize 16M
# php_value post_max_size 16M
# php_value max_execution_time 300
# php_value memory_limit 256M


# ==============================================================================
# 16. CHARACTER SET
# ==============================================================================

AddDefaultCharset UTF-8
<IfModule mod_mime.c>
    AddCharset UTF-8 .html .css .js .json .xml .txt .webmanifest
</IfModule>


# ==============================================================================
# 17. DIRECTORY INDEX
# ==============================================================================

DirectoryIndex index.html index.htm index.php


# ==============================================================================
# 18. PROTECT wp-login / xmlrpc (if WordPress added later)
# ==============================================================================

<FilesMatch "^(xmlrpc\.php|wp-login\.php)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>


# ==============================================================================
# 19. SPEED: DISABLE UNUSED APACHE FEATURES
# ==============================================================================

<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>


# ==============================================================================
# END OF .htaccess
# ==============================================================================
